APP_NAME="GoodGasoilPrice"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://votre-domaine.railway.app

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

# Driver de cache : fichier (pas de Redis en V1)
CACHE_STORE=file
CACHE_PREFIX=goodgasoilprice

# Pas de base de données en V1
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Logs applicatifs
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Sessions (driver fichier, pas de cookies tiers)
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# File system
FILESYSTEM_DISK=local

# Queue (synchrone en V1, pas de workers)
QUEUE_CONNECTION=sync

# Broadcast (désactivé en V1)
BROADCAST_CONNECTION=log

# -------------------------------------------------------------------------
# Clés API externes
# -------------------------------------------------------------------------

# Alpha Vantage — fallback si Yahoo Finance échoue pour le cours du Brent
# Clé gratuite disponible sur : https://www.alphavantage.co/support/#api-key
# ALPHA_VANTAGE_KEY=votre_cle_ici

# Frankfurter API — taux EUR/USD (aucune clé requise, gratuit)
# URL : https://api.frankfurter.app/latest?from=USD&to=EUR
